<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Post-it - Application Sociale</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <header id="header">
        <div class="header-left">
            <img src="/images/f72bf37e857e7eb7637784eaafefd41a.jpg" alt="Logo" class="header-logo">
        </div>
        <h1>Post-it Social</h1>
        <nav id="auth-nav">
            {% if userId %}
                <button id="add-note-btn" class="btn-add-note">+ Add Note</button>
                <span class="welcome-msg">Welcome back, {{ username }}!</span>
                <button id="logout-btn" class="btn btn-logout">Logout</button>
            {% else %}
                <span class="guest-msg">👤 Hello guest, you can view notes</span>
                <button id="login-btn" class="btn btn-login">Login</button>
                <button id="signup-btn" class="btn btn-signup">Sign Up</button>
            {% endif %}
        </nav>
    </header>

    <!-- SVG for drawing connection lines -->
    <svg id="connections-canvas" class="connections-canvas"></svg>

    <div id="postits-container" class="scroll-container"></div>

    <!-- Modal pour créer un post-it -->
    <div id="create-modal" class="modal hidden">
        <div class="modal-content note-modal">
            <h2>Create a New Note</h2>
            <textarea id="postit-text" placeholder="Write your note here..." maxlength="500"></textarea>
            <div class="modal-buttons">
                <button id="save-postit-btn" class="btn btn-success">Create</button>
                <button id="cancel-postit-btn" class="btn btn-secondary">Cancel</button>
            </div>
        </div>
    </div>

    <!-- Modal pour non-loggé essayant de poster -->
    <div id="guest-post-modal" class="modal hidden">
        <div class="modal-content auth-modal-content">
            <div class="auth-modal-wrapper">
                <!-- Left side: Picture -->
                <div class="auth-modal-image">
                    <div class="image-placeholder">
                        <span>📝</span>
                    </div>
                </div>

                <!-- Right side: Message and Buttons -->
                <div class="auth-modal-form">
                    <h2>Post a Note</h2>
                    <p style="font-size: 16px; margin-bottom: 20px; line-height: 1.5; color: white;">
                        To post a note you must login to your account or create one
                    </p>
                    <button id="guest-login-btn" class="btn btn-primary" style="width: 100%; margin-bottom: 10px;">Login</button>
                    <button id="guest-signup-btn" class="btn btn-success" style="width: 100%; margin-bottom: 10px;">Sign Up</button>
                    <button id="guest-close-btn" class="btn btn-secondary" style="width: 100%;">Close</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal pour login/signup -->
    <div id="auth-modal" class="modal hidden">
        <div class="modal-content auth-modal-content">
            <div class="auth-modal-wrapper">
                <!-- Left side: Picture -->
                <div class="auth-modal-image">
                    <div class="image-placeholder">
                        <span>📝</span>
                    </div>
                </div>

                <!-- Right side: Form -->
                <div class="auth-modal-form">
                    <!-- Login Form -->
                    <div id="login-form" class="auth-form">
                        <h2>Login</h2>
                        <input type="text" id="login-username" placeholder="Username" required>
                        <input type="password" id="login-password" placeholder="Password" required>
                        <!-- Error message -->
                        <div id="login-error" style="background-color: #ffebee; color: #d32f2f; padding: 10px; border-radius: 5px; margin-bottom: 10px; display: none; font-weight: bold; text-align: center;"></div>
                        <button id="login-submit-btn" class="btn btn-primary" style="width: 100%;">Login</button>
                        <p style="text-align: center; margin-top: 10px; font-size: 14px;">
                            No account? <button id="switch-to-signup" class="link-btn">Sign Up</button>
                        </p>
                    </div>

                    <!-- Signup Form (hidden by default) -->
                    <div id="signup-form" class="auth-form hidden">
                        <h2>Sign Up</h2>
                        <input type="text" id="signup-username" placeholder="Username" required>
                        <input type="password" id="signup-password" placeholder="Password" required>
                        <input type="password" id="signup-password-confirm" placeholder="Confirm Password" required>
                        <!-- Password requirements -->
                        <div id="password-requirements" style="margin-top: 15px; margin-bottom: 15px; font-size: 12px; color: #666;">
                            <p style="font-weight: bold; margin-bottom: 8px;">Password Requirements:</p>
                            <div id="signup-req-length" style="margin: 3px 0; color: #999;">❌ At least 8 characters</div>
                            <div id="signup-req-upper" style="margin: 3px 0; color: #999;">❌ One uppercase (A-Z)</div>
                            <div id="signup-req-lower" style="margin: 3px 0; color: #999;">❌ One lowercase (a-z)</div>
                            <div id="signup-req-number" style="margin: 3px 0; color: #999;">❌ One number (0-9)</div>
                            <div id="signup-req-special" style="margin: 3px 0; color: #999;">❌ One special character (!@#$%^&*)</div>
                        </div>
                        <!-- Error message -->
                        <div id="signup-error" style="background-color: #ffebee; color: #d32f2f; padding: 10px; border-radius: 5px; margin-bottom: 10px; display: none; font-weight: bold; text-align: center;"></div>
                        <button id="signup-submit-btn" class="btn btn-primary" style="width: 100%;">Sign Up</button>
                        <p style="text-align: center; margin-top: 10px; font-size: 14px;">
                            Already have an account? <button id="switch-to-login" class="link-btn">Login</button>
                        </p>
                    </div>

                    <button id="close-auth-modal-btn" class="btn btn-secondary" style="width: 100%; margin-top: 10px;">Close</button>
                </div>
            </div>
        </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script src="/client.js"></script>
</body>
</html>
